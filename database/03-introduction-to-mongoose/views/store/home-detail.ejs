<%- include('../partials/head') %>
</head>

<body class="bg-gray-100 min-h-screen flex flex-col">

<%- include('../partials/nav') %>
<main class="flex-grow flex items-center justify-center pt-24 px-4">
<div class="bg-white rounded-xl shadow-lg overflow-hidden max-w-md w-full">
    <img  src="<%= home.photoUrl %>"  alt="<%= home.houseName %>" class="w-full h-56 object-cover">
    <div class="p-6">
        <h2 class="text-2xl font-bold text-gray-800 mb-2"><%= home.houseName %></h2>
        <p class="text-gray-500 mb-3">📍 <%= home.location %></p>
        <p class="text-rose-500 font-semibold text-lg mb-3">₹ <%= home.price %> / night</p>
        <p class="text-yellow-600 font-medium mb-4">⭐ <%= home.rating %> Rating</p>
        <button class="w-full bg-green-500 text-white py-2 rounded-lg hover:bg-green-600 transition">Book Now</button>
    </div>
    <div class="mt-1">
        <%- include('../partials/favourites') %>
    </div>
</div>
</main>

</body>
</html>