<%- include('../partials/head') %>
    </head>

    <body class="bg-gray-100 min-h-screen flex flex-col">

        <%- include('../partials/nav') %>

            <main class="flex-grow flex items-center justify-center pt-24">
                <div class="bg-white p-8 rounded-2xl shadow-lg w-[420px]">
                    <h1 class="text-2xl font-bold text-gray-800 mb-6 text-center">Register as a new user:</h1>
                    <form action="/signup" method="POST" class="space-y-4">

                        <!-- ERROR MESSAGE -->
                        <%- include('../partials/error') %>

                        <input type="text" name="firstName" placeholder="Enter your first name" class="w-full border border-gray-300 rounded-lg px-4 py-3 focus:ring-2 focus:ring-rose-400" required>
                        <input type="text" name="lastName" placeholder="Enter your last name" class="w-full border border-gray-300 rounded-lg px-4 py-3 focus:ring-2 focus:ring-rose-400">
                        <input type="email" name="email" placeholder="Enter your email" class="w-full border border-gray-300 rounded-lg px-4 py-3 focus:ring-2 focus:ring-rose-400">
                        <input type="password" name="password" placeholder="Enter your password" class="w-full border border-gray-300 rounded-lg px-4 py-3 focus:ring-2 focus:ring-rose-400" required>
                        <input type="password" name="confirmPassword" placeholder="Enter your confirm password" class="w-full border border-gray-300 rounded-lg px-4 py-3 focus:ring-2 focus:ring-rose-400" required>

                        <p class="">User Type:</p>
                        <div class="flex space-x-4">
                            <label class="flex items-center">
                                <input type="radio" name="userType" value="guest" id="guest" class="mr-2" checked />
                                <span>Guest</span>
                            </label>
                            <label>
                                <input type="radio" name="userType" value="host" id="host"  />
                                <span>Host</span>
                            </label>
                        </div>
                        <label class="block mb-3">
                            <input type="checkbox" name="terms" id="terms">
                            <span>I agree to the terms and condition</span>
                        </label>
                        <input type="submit" value="Register" class="w-full bg-rose-500 text-white py-3 rounded-lg font-semibold hover:bg-rose-600 transition" />
                    </form>
                </div>

            </main>
    </body>

    </html>