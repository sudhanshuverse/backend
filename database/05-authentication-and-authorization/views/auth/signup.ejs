<%- include('../partials/head') %>
    </head>

    <body class="bg-gray-100 min-h-screen flex flex-col">

        <%- include('../partials/nav') %>

            <main class="flex-grow flex items-center justify-center pt-24 px-4">

                <div class="bg-white p-8 rounded-2xl shadow-lg w-full max-w-md">

                    <h1 class="text-2xl font-bold text-gray-800 mb-6 text-center">
                        Register as a New User
                    </h1>

                    <form action="/signup" method="POST" class="space-y-4">

                        <!-- FIRST NAME -->
                        <div>
                            <input type="text" name="firstName" value="<%= old.firstName || '' %>"
                                placeholder="First name" class="w-full border border-gray-300 rounded-lg px-4 py-3">

                            <% if(errors.firstName){ %>
                                <p class="text-red-500 text-sm mt-1">
                                    <%= errors.firstName %>
                                </p>
                                <% } %>
                        </div>


                        <!-- LAST NAME -->
                        <div>
                            <input type="text" name="lastName" value="<%= old.lastName || '' %>" placeholder="Last name"
                                class="w-full border border-gray-300 rounded-lg px-4 py-3">

                            <% if(errors.lastName){ %>
                                <p class="text-red-500 text-sm mt-1">
                                    <%= errors.lastName %>
                                </p>
                                <% } %>
                        </div>


                        <!-- EMAIL -->
                        <div>
                            <input type="email" name="email" value="<%= old.email || '' %>"
                                placeholder="Enter your email"
                                class="w-full border border-gray-300 rounded-lg px-4 py-3">

                            <% if(errors.email){ %>
                                <p class="text-red-500 text-sm mt-1">
                                    <%= errors.email %>
                                </p>
                                <% } %>
                        </div>


                        <!-- PASSWORD -->
                        <div>
                            <input type="password" name="password" placeholder="Enter your password"
                                class="w-full border border-gray-300 rounded-lg px-4 py-3">

                            <% if(errors.password){ %>
                                <p class="text-red-500 text-sm mt-1">
                                    <%= errors.password %>
                                </p>
                                <% } %>
                        </div>


                        <!-- CONFIRM PASSWORD -->
                        <div>
                            <input type="password" name="confirmPassword" placeholder="Confirm password"
                                class="w-full border border-gray-300 rounded-lg px-4 py-3">

                            <% if(errors.confirmPassword){ %>
                                <p class="text-red-500 text-sm mt-1">
                                    <%= errors.confirmPassword %>
                                </p>
                                <% } %>
                        </div>


                        <!-- USER TYPE -->
                        <div>

                            <p class="text-gray-700 font-medium mb-2">User Type</p>

                            <div class="flex gap-6">

                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input type="radio" name="userType" value="guest" <%=old.userType==='host' ? ''
                                        : 'checked' %>>
                                    <span>Guest</span>
                                </label>

                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input type="radio" name="userType" value="host" <%=old.userType==='host'
                                        ? 'checked' : '' %>>
                                    <span>Host</span>
                                </label>

                            </div>

                            <% if(errors.userType){ %>
                                <p class="text-red-500 text-sm mt-1">
                                    <%= errors.userType %>
                                </p>
                                <% } %>

                        </div>


                        <!-- TERMS -->
                        <label class="flex items-center gap-2 text-sm text-gray-700 cursor-pointer">

                            <input type="checkbox" name="terms" <%=old.terms ? 'checked' : '' %>>

                            <span>I agree to the terms and conditions</span>

                        </label>

                        <% if(errors.terms){ %>
                            <p class="text-red-500 text-sm mt-1">
                                <%= errors.terms %>
                            </p>
                            <% } %>


                                <!-- SUBMIT -->
                                <input type="submit" value="Register"
                                    class="w-full bg-rose-500 text-white py-3 rounded-lg font-semibold hover:bg-rose-600 transition duration-200 cursor-pointer">

                    </form>

                </div>

            </main>

    </body>

    </html>