<%- include('../partials/head') %>
    </head>

    <body class="bg-gray-100 min-h-screen flex flex-col">

        <%- include('../partials/nav') %>

            <main class="flex-grow flex items-center justify-center pt-24">
                <div class="bg-white p-8 rounded-2xl shadow-lg w-[420px]">
                    <h1 class="text-2xl font-bold text-gray-800 mb-6 text-center">Login with your info</h1>
                    <form action="/login" method="POST" class="space-y-4">
                        <input type="text" name="username" placeholder="Enter your username" class="w-full border border-gray-300 rounded-lg px-4 py-3 focus:ring-2 focus:ring-rose-400" required>
                        <input type="password" name="password" placeholder="Enter your password" class="w-full border border-gray-300 rounded-lg px-4 py-3 focus:ring-2 focus:ring-rose-400" required>
                        <input type="submit" value="Sign in" class="w-full bg-rose-500 text-white py-3 rounded-lg font-semibold hover:bg-rose-600 transition"/>
                    </form>
                </div>

            </main>
    </body>

    </html>