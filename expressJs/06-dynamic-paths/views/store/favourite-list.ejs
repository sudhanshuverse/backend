<%- include('../partials/head') %>
</head>

<body class="bg-gray-100 min-h-screen flex flex-col">

    <%- include('../partials/nav')%>

    <main class="flex-grow pt-28 px-6">
        <h2 class="text-4xl font-bold text-center text-gray-800 mb-10">Here is my favourites:</h2>
        <div class="max-w-6xl mx-auto grid md:grid-cols-3 gap-8">
        <% if (favouriteHomes.length === 0) { %>
            <p class="text-center text-gray-500 col-span-3">No homes registered yet.</p>
        <% } %>
        <% favouriteHomes.forEach(home => { %>
            <div class="bg-white rounded-2xl shadow-lg overflow-hidden hover:shadow-2xl transition">
                <img src="<%= home.photo %>" alt="home"
                class="w-full h-52 object-cover">
                <div class="p-5">
                    <h3 class="text-xl font-bold text-gray-800 mb-1"><%= home.houseName %></h3>
                    <p class="text-gray-500 mb-2">📍 <%= home.location %></p>
                    <div class="flex justify-between items-center mt-3">
                        <span class="text-rose-500 font-bold text-lg">₹<%= home.price %> / night</span>
                        <span class="bg-yellow-100 text-yellow-700 px-3 py-1 rounded-full text-sm font-semibold">⭐ <%= home.rating %></span>
                    </div>
                    <form action="/favourites/delete/<%= home.id %>" method="POST">
                        <button type="submit" class="bg-red-500 p-1.5">Remove from favourites</button>
                    </form>
                </div>
            </div>
        <% }) %>
        </div>
    </main>

</body>
</html>