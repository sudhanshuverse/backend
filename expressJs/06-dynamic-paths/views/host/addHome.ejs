<%- include('../partials/head') %>
</head>

<body class="bg-gray-100 min-h-screen flex flex-col">

    <%- include('../partials/nav') %>

    <main class="flex-grow flex items-center justify-center pt-24">
        <div class="bg-white p-8 rounded-2xl shadow-lg w-[420px]">
            <h1 class="text-2xl font-bold text-gray-800 mb-6 text-center">Register your home</h1>
            <form action="/host/add-home" method="POST" class="space-y-4">
                <input type="text" name="houseName" placeholder="House Name" class="w-full border border-gray-300 rounded-lg px-4 py-3 focus:ring-2 focus:ring-rose-400" required>
                <input type="text" name="location" placeholder="Location (City)"class="w-full border border-gray-300 rounded-lg px-4 py-3 focus:ring-2 focus:ring-rose-400" required>
                <input type="number" name="price" placeholder="Price per night (₹)" class="w-full border border-gray-300 rounded-lg px-4 py-3 focus:ring-2 focus:ring-rose-400" required>
                <input type="number" step="0.1" min="1" max="5" name="rating" placeholder="Rating (1 - 5)" class="w-full border border-gray-300 rounded-lg px-4 py-3 focus:ring-2 focus:ring-rose-400" required>
                <input type="text" name="photo" placeholder="Photo URL (paste image link)" class="w-full border border-gray-300 rounded-lg px-4 py-3 focus:ring-2 focus:ring-rose-400" required>
                <button type="submit" class="w-full bg-rose-500 text-white py-3 rounded-lg font-semibold hover:bg-rose-600 transition"> Add Home</button>
            </form>
        </div>

    </main>
</body>
</html>